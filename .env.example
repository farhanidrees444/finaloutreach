# ============================================================
# FinalOutreach — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit secrets. .env.local is git-ignored by default.
# ============================================================

# ---- Email delivery (REQUIRED for contact form, newsletter, lead magnet) ----
# Create an API key at https://resend.com
RESEND_API_KEY=
# Where contact form submissions are routed (your inbox).
CONTACT_EMAIL_TO=hello@finaloutreach.com
# The verified "from" address in Resend (must be on a verified domain).
CONTACT_EMAIL_FROM=notifications@finaloutreach.com

# ---- Supabase (OPTIONAL — used to also persist submissions) ----
# Create a project at https://supabase.com and run scripts/001_create_contact_tables.sql
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Analytics (OPTIONAL — heatmaps + conversion tracking) ----
# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
# Microsoft Clarity project ID, e.g. abc123xyz
NEXT_PUBLIC_CLARITY_ID=

# ---- Site (optional override; otherwise uses lib/site-data.ts SITE.domain) ----
NEXT_PUBLIC_SITE_URL=
